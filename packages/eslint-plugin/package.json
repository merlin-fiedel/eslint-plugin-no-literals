{
  "name": "eslint-plugin-no-literals",
  "version": "0.1.2",
  "description": "ESLint plugin that flags hardcoded string literals inside TypeScript class bodies",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin",
    "typescript",
    "angular",
    "i18n",
    "literals",
    "no-literals",
    "hardcoded-strings",
    "lint"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/merlin-fiedel/eslint-plugin-no-literals.git",
    "directory": "packages/eslint-plugin"
  },
  "bugs": {
    "url": "https://github.com/merlin-fiedel/eslint-plugin-no-literals/issues"
  },
  "homepage": "https://github.com/merlin-fiedel/eslint-plugin-no-literals/tree/main/packages/eslint-plugin#readme",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": ">=7.0.0",
    "eslint": ">=9.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
